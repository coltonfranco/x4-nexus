{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "X4 Nexus",
  "version": "0.0.1",
  "identifier": "com.x4nexus.desktop",
  "build": {
    "frontendDist": "../../x4-dashboard/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../x4-dashboard run dev",
    "beforeBuildCommand": "npm --prefix ../x4-dashboard run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "X4 Nexus",
        "width": 1480,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
