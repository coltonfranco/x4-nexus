{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "X4 Nexus",
  "version": "0.0.0",
  "identifier": "com.x4nexus.desktop",
  "build": {
    "frontendDist": "../loader",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../x4-dashboard run dev",
    "beforeBuildCommand": "npm --prefix ../x4-dashboard run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "X4 Nexus",
        "width": 1480,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "backgroundColor": "#04060c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "resources/server": "server",
      "resources/dashboard": "dashboard"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1OEJGRUM4MUZBRTM4MzMKUldRek9LNGZ5UDZMbGZFOGNIdG5WSkpZNG5qOEdmQ2JMMnJtMVpYcFBnU3VRNXZyLzYxeDV5cUkK",
      "endpoints": [
        "https://github.com/coltonfranco/x4-nexus/releases/download/v0.0.3/latest.json",
        "https://github.com/coltonfranco/x4-nexus/releases/latest/download/latest.json"
      ]
    }
  }
}
