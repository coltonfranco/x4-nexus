{
  "_doc": "Logbook classification rules.  Patterns are matched against lowercased entry titles in priority order — first match wins.  When no pattern matches, native_fallback maps the game's category attribute to a resolved category/subcategory.  See docs/logbook-categories.md for the template reference.",
  "native_fallback": {
    "tips":    ["tips", "tip"],
    "news":    ["news", "news"],
    "missions": ["missions", "update"],
    "alerts":  ["alerts", "warning"]
  },
  "categories": {
