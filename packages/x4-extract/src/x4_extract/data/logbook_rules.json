      "label": "Combat",
      "subcategories": {
        "destroyed": {
          "label": "Destroyed",
          "patterns": ["was destroyed", "has been destroyed", "were destroyed", "have been destroyed"]
        },
        "attack": {
          "label": "Under Attack",
          "patterns": ["is under attack", "are under attack", "forced to flee after being attacked", "under attack"]
        },
        "hostile": {
          "label": "Hostile Detected",
          "patterns": ["hostile object", "hostile ship", "hostile station", "hostile objects", "hostile ships", "hostile stations", "early warning system"]
        },
        "ammo": {
          "label": "Out of Ammo",
          "patterns": ["out of ammo", "ran out of ammunition"]
        }
      }
    },
    "personnel": {
      "label": "Personnel",
      "subcategories": {
        "assigned": {
