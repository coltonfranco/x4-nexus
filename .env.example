# X4: Foundations game install — folder containing X4.exe and the .cat/.dat archives
X4C_INSTALL_PATH=G:\SteamLibrary\steamapps\common\X4 Foundations

# Save folder — the directory directly containing *.xml.gz files.
# Default Egosoft path: %USERPROFILE%\Documents\Egosoft\X4\<profile-id>\save\
# This repo's dev has saves at a non-default location:
X4C_SAVE_PATH=C:\Users\colto\sss\Documents\Egosoft\X4\59308344\save

# Where to write static.db, dynamic.db, extracted XML cache, and icons.
# Defaults to packages/x4-api/data/ if unset.
X4C_DATA_DIR=

# Bind address for the local API server. Default :8765.
X4C_HOST=127.0.0.1
X4C_PORT=8765

# Save poll cadence in seconds (file-stat check; parse only fires on change). Default 60.
X4C_POLL_INTERVAL_SEC=60
